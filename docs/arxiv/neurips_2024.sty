% neurips_2024.sty — Simplified NeurIPS-like style for arXiv preprints
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS-like style]

% Page geometry
\RequirePackage[
  textwidth=5.5in,
  textheight=9in,
  top=1in,
  headheight=12pt,
  headsep=25pt,
  footskip=30pt
]{geometry}

% Fonts
\RequirePackage{times}
\RequirePackage{microtype}

% Spacing
\RequirePackage{setspace}
\setstretch{1.05}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{12pt plus 2pt minus 2pt}{6pt plus 1pt minus 1pt}
\titlespacing*{\subsection}{0pt}{8pt plus 2pt minus 2pt}{4pt plus 1pt minus 1pt}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5em}%
  \begin{quote}\small
}{%
  \end{quote}\vspace{1em}
}

% Title
\RequirePackage{authblk}

% Caption
\RequirePackage[font=small,labelfont=bf]{caption}

% Header
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}

% Colors for links
\RequirePackage{xcolor}
\RequirePackage[colorlinks=true,citecolor=blue!60!black,linkcolor=blue!60!black,urlcolor=blue!60!black]{hyperref}

\endinput
