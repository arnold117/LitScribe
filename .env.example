# ==============================================
# LitScribe v4 环境配置
# ==============================================
# cp .env.example .env && 填入真实值

# ----------------------------------------------
# LLM 配置 (必填)
# ----------------------------------------------
# Provider: openai | anthropic | ollama
# "openai" 支持所有兼容端点 (DeepSeek / 百炼 / OpenAI / Together / Groq / OpenRouter)
# LLM_PROVIDER=openai

llm-key=sk-your-key
llm-location=https://api.deepseek.com/
llm-model=deepseek-v4-pro

# 可选: reasoning model (不填则跟 llm-model 一样)
# LLM_REASONING_MODEL=deepseek-reasoner

# --- Anthropic 示例 ---
# LLM_PROVIDER=anthropic
# llm-key=sk-ant-your-key
# llm-model=claude-sonnet-4-20250514

# --- Ollama 本地 示例 ---
# LLM_PROVIDER=ollama
# llm-location=http://localhost:11434
# llm-model=llama3

# ----------------------------------------------
# 学术搜索 API (推荐, 不填也能用)
# ----------------------------------------------
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=your-ncbi-api-key
# SEMANTIC_SCHOLAR_API_KEY=your-s2-key

# ----------------------------------------------
# 可选
# ----------------------------------------------
# ZOTERO_API_KEY=your-zotero-key
# ZOTERO_LIBRARY_ID=your-library-id
# LITSCRIBE_DATA_DIR=~/.litscribe/data
# LITSCRIBE_OUTPUT_DIR=~/.litscribe/output
