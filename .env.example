# ==============================================
# LitScribe v4 环境配置
# ==============================================
# cp .env.example .env && 填入真实值

# ----------------------------------------------
# LLM 配置 (必填)
# ----------------------------------------------
# 任何 OpenAI 兼容端点都行 (DeepSeek / 百炼 / OpenAI / Ollama / ...)
LLM_API_KEY=sk-your-key
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 可选: reasoning model (不填则跟 LLM_MODEL 一样)
# LLM_REASONING_MODEL=deepseek-reasoner

# ----------------------------------------------
# 学术搜索 API (推荐, 不填也能用)
# ----------------------------------------------
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=your-ncbi-api-key
# S2_API_KEY=your-s2-key

# ----------------------------------------------
# 可选
# ----------------------------------------------
# ZOTERO_API_KEY=your-zotero-key
# ZOTERO_LIBRARY_ID=your-library-id
# LITSCRIBE_DATA_DIR=~/.litscribe/data
