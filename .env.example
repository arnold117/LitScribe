# ==============================================
# LitScribe v4 环境配置
# ==============================================
# 复制到 .env 并填入真实值: cp .env.example .env

# ----------------------------------------------
# LLM 配置 (必填, 二选一)
# ----------------------------------------------

# 方案 A: DeepSeek 官方 API (推荐)
# 申请: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
# LITSCRIBE_DEFAULT_MODEL=deepseek/deepseek-chat

# 方案 B: 百炼 DashScope API
# 申请: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# LITSCRIBE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LITSCRIBE_DEFAULT_MODEL=openai/qwen-plus

# ----------------------------------------------
# 学术搜索 API (推荐填写, 不填也能用)
# ----------------------------------------------
# PubMed — 生物医学必备
# 注册: https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=your-ncbi-api-key

# Semantic Scholar — 全学科, 提高搜索覆盖
# 申请: https://www.semanticscholar.org/product/api#api-key
# S2_API_KEY=your-s2-key

# ----------------------------------------------
# Zotero 个人文库 (可选)
# ----------------------------------------------
# ZOTERO_API_KEY=your-zotero-key
# ZOTERO_LIBRARY_ID=your-library-id

# ----------------------------------------------
# 应用配置 (可选)
# ----------------------------------------------
# LITSCRIBE_DATA_DIR=~/.litscribe/data
# LITSCRIBE_LOG_LEVEL=INFO
